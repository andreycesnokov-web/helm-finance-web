# CFO AI Telegram bot — environment
# Telegram bot token from @BotFather
BOT_TOKEN=

# CFO AI backend base URL (no trailing slash), e.g. https://helm-finance-web-production.up.railway.app
CFO_API_URL=

# Shared secret — MUST equal the web backend's TELEGRAM_WEBHOOK_SECRET.
# If unset, the bot falls back to BOT_TOKEN (backend does the same).
TELEGRAM_WEBHOOK_SECRET=
